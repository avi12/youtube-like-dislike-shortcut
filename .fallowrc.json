{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "wxt.config.ts",
    "web-ext.config.ts",
    "src/entrypoints/popup/main.ts",
    "src/entrypoints/ytr-trigger.content.ts",
    "src/entrypoints/ytr-rate-api.content.ts",
    "src/entrypoints/auto-like-percentage.content/index.ts",
    "src/entrypoints/auto-like-in-subscription.content.ts"
  ],
  "ignorePatterns": [
    "tests/**"
  ],
  "ignoreDependencies": [
    "#imports",
    "@stylistic/stylelint-plugin",
    "@sveltejs/vite-plugin-svelte",
    "@wxt-dev/module-svelte",
    "postcss-html"
  ],
  "rules": {
    "unused-enum-members": "off",
    "unresolved-imports": "off"
  }
}
