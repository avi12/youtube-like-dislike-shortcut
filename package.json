{
  "name": "youtube-like-dislike-shortcut",
  "version": "2.4.2",
  "description": "Like videos with Shift+Plus or Numpad Plus, dislike with Shift+Minus or Numpad Minus.",
  "repository": "https://github.com/avi12/youtube-like-dislike-shortcut",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "Avi <avi6106@gmail.com>",
  "homepage": "https://avi12.com/youtube-like-dislike-shortcut",
  "scripts": {
    "dev": "wxt",
    "dev:rtl": "set VITE_LANG=he && wxt",
    "dev:edge": "bun dev -b edge",
    "dev:opera": "bun dev -b opera",
    "build": "wxt build --mode prod",
    "build:edge": "bun build -b edge",
    "build:opera": "bun build -b opera",
    "build:firefox": "bun build -b firefox --mv3",
    "package": "wxt zip --mode prod",
    "package:edge": "bun run package -b edge",
    "package:opera": "bun run package -b opera",
    "package:firefox": "bun run package -b firefox --mv3",
    "build:package": "bun build && bun package",
    "build:package:edge": "bun build:edge && bun package:edge",
    "build:package:opera": "bun build:opera && bun package:opera",
    "build:package:firefox": "bun build:firefox && bun package:firefox",
    "build:package:all": "concurrently \"bun build:package\" \"bun build:package:edge\" \"bun build:package:opera\" \"bun build:package:firefox\" --names Chrome,Edge,Opera,Firefox",
    "svelte:check": "svelte-check --tsconfig ./tsconfig.json",
    "lint:fix": "eslint --fix",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/chrome": "^0.1.37",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@wxt-dev/module-svelte": "^2.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-avi12": "github:avi12/eslint-config-avi12",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "svelte-eslint-parser": "^1.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "wxt": "^0.20.18"
  }
}
