{
  "name": "youtube-like-dislike-shortcut",
  "version": "2.5.6",
  "description": "Like videos with Shift+Plus or Numpad Plus, dislike with Shift+Minus or Numpad Minus.",
  "repository": "https://github.com/avi12/youtube-like-dislike-shortcut",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "Avi <avi6106@gmail.com>",
  "homepage": "https://avi12.com/youtube-like-dislike-shortcut",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "wxt",
    "dev:with-profile": "pnpx cross-env CHROME_WITH_PROFILE=1 wxt",
    "dev:rtl": "pnpx cross-env LANG=he wxt",
    "dev:opera": "pnpm dev -b opera",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:firefox:with-profile": "pnpx cross-env FIREFOX_WITH_PROFILE=1 wxt -b firefox --mv3",
    "build": "wxt build --mode prod",
    "build:opera": "pnpm build -b opera",
    "build:firefox": "pnpm build -b firefox --mv3",
    "package": "wxt zip --mode prod",
    "package:opera": "pnpm package -b opera",
    "package:firefox": "pnpm package -b firefox --mv3",
    "build:package": "pnpm build && pnpm package",
    "build:package:opera": "pnpm build:opera && pnpm package:opera",
    "build:package:firefox": "pnpm build:firefox && pnpm package:firefox",
    "build:package:all": "concurrently \"pnpm build:package\" \"pnpm build:package:opera\" \"pnpm build:package:firefox\" --names Chrome,Opera,Firefox",
    "svelte:check": "pnpx svelte-check",
    "lint:fix": "eslint --fix",
    "stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "postinstall": "wxt prepare"
  },
  "pnpm": {
    "overrides": {
      "acorn": "8.16.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@wxt-dev/module-svelte": "2.0.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-config-avi12": "github:avi12/eslint-config-avi12",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "knip": "^6.14.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.11.1",
    "stylelint-config-ccb": "^3.31.5",
    "svelte": "5.55.7",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "wxt": "0.20.26"
  },
  "dependencies": {
    "@webext-core/messaging": "^2.3.0"
  }
}
