{
  "name": "youtube-like-dislike-shortcut",
  "version": "2.5.3",
  "description": "Like videos with Shift+Plus or Numpad Plus, dislike with Shift+Minus or Numpad Minus.",
  "repository": "https://github.com/avi12/youtube-like-dislike-shortcut",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "Avi <avi6106@gmail.com>",
  "homepage": "https://avi12.com/youtube-like-dislike-shortcut",
  "scripts": {
    "dev": "wxt",
    "dev:with-profile": "bunx cross-env CHROME_WITH_PROFILE=1 wxt",
    "dev:rtl": "bunx cross-env LANG=he wxt",
    "dev:edge": "bun dev -b edge",
    "dev:opera": "bun dev -b opera",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:firefox:with-profile": "bunx cross-env FIREFOX_WITH_PROFILE=1 wxt -b firefox --mv3",
    "build": "wxt build --mode prod",
    "build:edge": "bun run build -b edge",
    "build:opera": "bun run build -b opera",
    "build:firefox": "bun run build -b firefox --mv3",
    "package": "wxt zip --mode prod",
    "package:edge": "bun run package -b edge",
    "package:opera": "bun run package -b opera",
    "package:firefox": "bun run package -b firefox --mv3",
    "build:package": "bun run build && bun run package",
    "build:package:edge": "bun build:edge && bun package:edge",
    "build:package:opera": "bun build:opera && bun package:opera",
    "build:package:firefox": "bun build:firefox && bun package:firefox",
    "build:package:all": "bunx concurrently \"bun build:package\" \"bun build:package:edge\" \"bun build:package:opera\" \"bun build:package:firefox\" --names Chrome,Edge,Opera,Firefox",
    "svelte:check": "bunx svelte-check",
    "lint:fix": "eslint --fix",
    "stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "postinstall": "wxt prepare"
  },
  "overrides": {
    "acorn": "8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/chrome": "^0.1.40",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@wxt-dev/module-svelte": "2.0.5",
    "eslint": "^10.2.0",
    "eslint-config-avi12": "github:avi12/eslint-config-avi12",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "knip": "^6.4.1",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.7.0",
    "stylelint-config-ccb": "^3.31.2",
    "svelte": "5.55.4",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "wxt": "0.20.22"
  },
  "dependencies": {
    "@webext-core/messaging": "^2.3.0"
  }
}
